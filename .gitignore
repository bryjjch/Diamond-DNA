# Python Virtual Environment
venv/
*.pyc
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Terraform
# Local .tfvars files - may contain sensitive data
*.tfvars
*.tfvars.json

# Terraform state files
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup

# Override files - may contain sensitive data
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore lock files (optional - some teams prefer to commit these)
# .terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.auto.tfvars
*.auto.tfvars.json

# Include tfvars.example files (safe to commit)
!*.tfvars.example
!*.tfvars.json.example

# Frontend / Next.js
# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/
next-env.d.ts

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
