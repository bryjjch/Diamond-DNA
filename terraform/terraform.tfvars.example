# =============================================================================
# Diamond DNA Terraform Variables
# =============================================================================
# Copy this file to terraform.tfvars and set values. S3 bucket names must be
# globally unique across all AWS accounts.
# =============================================================================

# -----------------------------------------------------------------------------
# Required (no defaults)
# -----------------------------------------------------------------------------
data_lake_bucket_name       = "diamond-dna"   # Medallion data lives under bronze/silver/gold prefixes

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
region      = "us-east-1"
environment = "dev"
name_prefix = "diamonddna"

# Optional: extra tags applied to all resources
tags = {
  # Owner = "data-team"
  # CostCenter = "diamond-dna"
}

# -----------------------------------------------------------------------------
# Bronze Statcast pitch ingestion Lambda (daily run; same image used for backfill)
# -----------------------------------------------------------------------------
statcast_ingestion_s3_prefix             = "bronze/statcast"
statcast_ingestion_schedule_expression   = "cron(0 6 * * ? *)"  # 6 AM UTC daily
statcast_ingestion_memory_size           = 1024
statcast_ingestion_timeout               = 300
statcast_ingestion_image_tag             = "latest"

# -----------------------------------------------------------------------------
# Silver feature Lambda (daily run; bronze Statcast dailies → silver player-year features)
# -----------------------------------------------------------------------------
statcast_silver_s3_prefix                = "silver/statcast"
statcast_gold_s3_prefix                  = "gold/statcast"
statcast_by_player_schedule_expression   = "cron(15 6 * * ? *)"  # 6:15 AM UTC daily
statcast_by_player_memory_size           = 1024
statcast_by_player_timeout               = 900
statcast_by_player_image_tag             = "latest"

log_retention_days = 14